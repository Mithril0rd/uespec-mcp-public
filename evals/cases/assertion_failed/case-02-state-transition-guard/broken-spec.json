{
  "apiVersion": "0.2",
  "kind": "HUD",
  "name": "AssertionStateHUD",
  "stateMachine": {
    "initial": "Normal",
    "states": [
      {
        "name": "Normal",
        "transitions": [
          {
            "to": "Cooldown",
            "when": "onSkillUseed"
          }
        ]
      },
      {
        "name": "Cooldown"
      }
    ]
  },
  "root": {
    "id": "rootPanel",
    "type": "CanvasPanel"
  }
}
