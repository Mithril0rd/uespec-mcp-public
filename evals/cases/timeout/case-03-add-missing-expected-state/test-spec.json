{
  "apiVersion": "0.2",
  "kind": "Test",
  "name": "TimeoutMissingStateTest",
  "testSpec": {
    "target": "TimeoutMissingStateHUD",
    "phases": {
      "act": [
        {
          "step": "emit cooldown signal",
          "emitSignal": "onSkillUsed"
        }
      ],
      "assert": [
        {
          "step": "wait cooldown",
          "waitForState": {
            "state": "Cooldown",
            "timeout": 1
          }
        }
      ]
    }
  }
}
